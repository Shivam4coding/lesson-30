<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Registration Form</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #6a11cb, #2575fc);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .container {
            background: #fff;
            width: 360px;
            padding: 25px;
            border-radius: 18px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, .25);
            text-align: center;
        }

        h1 {
            color: #6a11cb;
            margin-bottom: 5px;
        }

        p {
            color: #555;
        }

        input,
        select {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
            border: 2px solid #6a11cb;
            border-radius: 8px;
            font-size: 15px;
            box-sizing: border-box;
        }

        button {
            width: 100%;
            background: #6a11cb;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 25px;
            font-size: 16px;
            cursor: pointer;
            transition: .3s;
        }

        button:hover {
            background: #2575fc;
        }

        #message {
            margin-top: 15px;
            font-weight: bold;
        }

        #timer {
            color: #777;
            margin-top: 15px;
            font-size: 14px;
        }
    </style>
</head>

<body>

    <div class="container">
        <h1>Event Registration</h1>
        <p>Register to join our event</p>
        <input type="text" id="name" placeholder="Full Name">
        <input type="email" id="email" placeholder="Email Address">
        <input type="tel" id="phone" placeholder="Mobile Number">
        <select id="event">
            <option value="">Select Event</option>
            <option>Business Seminar</option>
            <option>Workshop</option>
            <option>Conference</option>
            <option>Networking Event</option>
        </select>

        <button onclick="register()">Register Now</button>
        <p id="message"></p>
        <p id="timer"></p>

    </div>
    <script>
        let seconds = 0;
        setInterval(function () {
            seconds++;
            document.getElementById("timer").innerHTML =
                "You have been on this page for " + seconds + " seconds";
        }, 1000);

        function register() {
            let name = document.getElementById("name").value;
            let email = document.getElementById("email").value;
            let phone = document.getElementById("phone").value;
            let event = document.getElementById("event").value;

            if (name == "" || email == "" || phone == "" || event == "") {
                document.getElementById("message").innerHTML = "Please fill all fields.";
                document.getElementById("message").style.color = "red";
            }
            else {
                document.getElementById("message").innerHTML =
                    "🎉 Registration Successful! Thank you, " + name + ".";
                document.getElementById("message").style.color = "green";
            }

        }

    </script>

</body>

</html>